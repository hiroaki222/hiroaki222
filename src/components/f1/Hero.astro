---
// formula1.com driver hero の再現 (inset 角丸カード).
// 左半分: f1.com の info column 構造そのまま (flex column, justify-between,
//         RacingLine(top) / name+meta+cta / RacingLine(bottom) が上下端に張り付く).
// 右半分: tone-on-tone の巨大 number + 階段 pixel パターン, photo が前面.
// RacingLine は f1.com の SVG 実測値を再現: 幅 36px, 45° カット,
// bar 17px + gap 2px + bar 17px, 下グループのみ浮き斜め帯 (垂直厚 23px).
interface Props {
  firstName: string
  lastName: string
  nation: string
  nationCode: string
  clubName: string
  shirtNumber: string
  photoSrc?: string | null
  ctaHref?: string
  ctaLabel?: string
}
const {
  firstName,
  lastName,
  nation,
  clubName,
  shirtNumber,
  photoSrc = null,
  ctaHref = 'https://github.com/hiroaki222',
  ctaLabel = 'GitHub',
} = Astro.props
---

<section class="hero-wrap">
  <div class="hero-card">
    <div class="deco r-steps" aria-hidden="true"></div>
    <div class="deco r-steps2" aria-hidden="true"></div>
    <div class="deco r-dots" aria-hidden="true"></div>
    <div class="deco r-dots2" aria-hidden="true"></div>
    <div class="deco l-steps" aria-hidden="true"></div>
    <div class="deco l-dots" aria-hidden="true"></div>
    <div class="bg-number" aria-hidden="true">{shirtNumber}</div>
    {photoSrc && <img src={photoSrc} alt={lastName} class="photo" />}

    <div class="info">
      <div class="rline top" aria-hidden="true"></div>
      <div class="content">
        <div class="name-group">
          <h1><span class="first">{firstName}</span>{lastName}</h1>
          <div class="meta">
            <span class="item"><img class="flag" src="/japan-circle.png" alt="" />{nation}</span>
            <span class="sep"></span>
            <span class="item">{clubName}</span>
            <span class="sep"></span>
            <span class="item">{shirtNumber}</span>
          </div>
        </div>
        <a class="cta" href={ctaHref} target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
          {ctaLabel}
        </a>
      </div>
      <div class="rline bottom" aria-hidden="true"></div>
    </div>
  </div>
</section>

<style>
  .hero-wrap {
    background: var(--f1-dark);
    padding: 0 48px;
  }
  @media (max-width: 720px) {
    .hero-wrap { padding: 0 10px; }
  }

  .hero-card {
    position: relative;
    max-width: var(--container);
    margin: 0 auto;
    /* f1.com 実測: hero card はほぼ 3:1 */
    aspect-ratio: 3 / 1;
    min-height: 420px;
    overflow: hidden;
    /* 彩度を保った同系トーンで center-left (名前側) を明るく */
    background:
      radial-gradient(
        ellipse 58% 90% at 30% 45%,
        var(--team-primary-light) 0%,
        var(--team-primary) 55%,
        var(--team-primary-dark) 100%
      );
  }
  @media (max-width: 880px) {
    .hero-card { aspect-ratio: auto; min-height: 440px; }
  }

  /* ---- 装飾パターン (f1.com driver hero の再現) ----
   * 構成: 右側に大きい階段ブロック2層 (暗トーン) + halftone 網点パッチ,
   *       左下にも階段 + 網点. */
  .deco {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  /* 右: 粗い階段 (暗) — 下から右上へ昇る */
  .r-steps {
    background: rgba(0, 0, 0, 0.13);
    clip-path: polygon(
      64% 100%, 64% 78%,
      70% 78%, 70% 58%,
      76% 58%, 76% 40%,
      82% 40%, 82% 22%,
      88% 22%, 88% 6%,
      94% 6%, 94% 0%,
      100% 0%, 100% 100%
    );
  }
  /* 右: 2層目 (少し明るい, 半歩ずらし) — ブロックの重なり感 */
  .r-steps2 {
    background: rgba(255, 255, 255, 0.05);
    clip-path: polygon(
      68% 100%, 68% 88%,
      74% 88%, 74% 68%,
      80% 68%, 80% 50%,
      86% 50%, 86% 32%,
      92% 32%, 92% 14%,
      100% 14%, 100% 100%
    );
  }
  /* 右: halftone 網点 (暗) — 階段の縁に沿ったパッチ */
  .r-dots {
    background-image: radial-gradient(circle, rgba(0, 0, 0, 0.2) 2.4px, transparent 2.5px);
    background-size: 14px 14px;
    clip-path: polygon(
      58% 100%, 58% 82%,
      64% 82%, 64% 62%,
      70% 62%, 70% 44%,
      76% 44%, 76% 26%,
      82% 26%, 82% 10%,
      88% 10%, 88% 26%,
      82% 26%, 82% 44%,
      76% 44%, 76% 62%,
      70% 62%, 70% 82%,
      64% 82%, 64% 100%
    );
  }
  /* 右: halftone 網点 (明, 上寄りのパッチ) */
  .r-dots2 {
    background-image: radial-gradient(circle, rgba(255, 255, 255, 0.13) 2px, transparent 2.1px);
    background-size: 12px 12px;
    clip-path: polygon(
      86% 0%, 100% 0%, 100% 34%, 92% 34%, 92% 18%, 86% 18%
    );
  }

  /* 左下: 階段 (暗) — 名前ブロックの下から左下へ降りる */
  .l-steps {
    background: rgba(0, 0, 0, 0.11);
    clip-path: polygon(
      0% 100%, 0% 72%,
      5% 72%, 5% 82%,
      11% 82%, 11% 90%,
      17% 90%, 17% 96%,
      23% 96%, 23% 100%
    );
  }
  /* 左下: halftone 網点パッチ */
  .l-dots {
    background-image: radial-gradient(circle, rgba(0, 0, 0, 0.17) 2.2px, transparent 2.3px);
    background-size: 13px 13px;
    clip-path: polygon(
      0% 58%, 6% 58%, 6% 72%, 12% 72%, 12% 86%, 0% 86%
    );
  }

  /* ---- 巨大 number (背景より暗い同系色, photo の後ろ) ---- */
  .bg-number {
    position: absolute;
    right: 5%;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-display);
    font-size: clamp(240px, 26vw, 430px);
    font-weight: 900;
    line-height: 0.78;
    letter-spacing: -0.06em;
    color: color-mix(in srgb, var(--team-primary) 48%, black);
    z-index: 1;
    pointer-events: none;
    user-select: none;
  }
  @media (max-width: 880px) {
    .bg-number {
      font-size: clamp(220px, 55vw, 340px);
      right: 0;
      top: auto;
      bottom: -6%;
      transform: none;
    }
  }

  /* 全身写真を拡大して card 下端で crop — f1.com と同じ頭〜股下の構図.
   * 画像は透過余白が大きい (頭 10.7% / 足 92.4% 位置) ため実測で逆算:
   * height 228% + top -17% → 頭が card 上端から ~7%, 股下が下端にくる */
  /* 人物が "22" の2桁の間に立つ位置 (数字センターに合わせる) */
  .photo {
    position: absolute;
    right: 10%;
    top: -17%;
    height: 228%;
    max-width: none;
    z-index: 2;
    object-fit: contain;
    object-position: top;
    filter: drop-shadow(0 18px 28px rgba(0, 0, 0, 0.35));
  }
  @media (max-width: 880px) {
    .photo { height: 190%; top: -10%; right: 4%; }
  }

  /* ---- info column (左半分, f1.com の実構造) ----
   * flex column + justify-between で RacingLine が card 上端/下端に張り付き,
   * name block が縦センターへ. 横は half の中央 (= card の 25%). */
  .info {
    position: absolute;
    inset: 0 50% 0 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    text-align: center;
    z-index: 3;
  }
  @media (max-width: 880px) {
    .info { inset: 0 30% 0 0; }
  }

  .content {
    flex: 1;
    /* min-height: auto (flex 既定) = 中身より小さくは潰れない.
     * 高さが足りない分は rline 側が縮んで吸収する (名前/CTA との被り防止) */
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-around;
    gap: 16px;
  }
  .name-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  /* ---- RacingLine: f1.com SVG 実測の再現 (lg: 36px 幅 / scale 0.18) ----
   * bar 17px + gap 2px + bar 17px を 1枚の 45° clip-path でカット →
   * 2本の切れ込みが同一斜線上 (ツラ). 45° なので幅 36px あたり垂直 36px.
   * top: 左短・右長 (本家 _top = 180° 回転). bottom: 左長・右短 + 浮き斜め帯
   * (本家実測: 垂直厚 23px ≈ 見た目 16px, バーとの隙間 ~3px ≈ 見た目 2px). */
  .rline {
    position: relative;
    width: 36px;
    height: 144px;
    /* アスペクト比の都合で縦が足りないときは rline が縮む
     * (clip-path が px 指定のため 70px を下限にする) */
    flex-shrink: 1;
    min-height: 70px;
    pointer-events: none;
  }
  @media (max-width: 880px) {
    .rline { height: 90px; }
  }
  .rline::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, white 0 17px, transparent 17px 19px, white 19px 36px);
  }
  .rline.top::before {
    clip-path: polygon(0 0, 100% 0, 100% 100%, 0 calc(100% - 36px));
  }
  .rline.bottom::before {
    clip-path: polygon(0 26px, 100% 62px, 100% 100%, 0 100%);
  }
  .rline.bottom::after {
    content: '';
    position: absolute;
    inset: 0;
    background: white;
    clip-path: polygon(0 0, 100% 36px, 100% 59px, 0 23px);
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(40px, 4.6vw, 64px);
    font-weight: 900;
    line-height: 0.95;
    text-transform: uppercase;
    letter-spacing: 0.01em;
    margin: 0;
    color: white;
  }
  h1 .first {
    display: block;
    font-size: 0.52em;
    font-weight: 400;
    letter-spacing: 0.06em;
    margin-bottom: 6px;
    opacity: 0.95;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 14px;
    font-family: var(--font-ui);
    font-size: 16px;
    font-weight: 600;
    color: white;
  }
  .item { display: inline-flex; align-items: center; gap: 8px; }
  .sep { width: 1px; height: 18px; background: rgba(255, 255, 255, 0.35); }
  /* f1.com の CountryFlag (円形 flag) と同じく丸型 */
  .flag {
    width: 20px; height: 20px;
    border-radius: 50%;
    display: inline-block;
    flex-shrink: 0;
  }

  .cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 9px 22px;
    border: 1.5px solid rgba(255, 255, 255, 0.85);
    border-radius: 999px;
    color: white;
    font-family: var(--font-ui);
    font-size: 14px;
    font-weight: 700;
    transition: background 0.15s;
  }
  .cta:hover {
    background: rgba(255, 255, 255, 0.12);
    text-decoration: none;
  }
  .cta svg { width: 15px; height: 15px; }

  /* ---- mobile: f1.com 公式のモバイル hero 構成 ----
   * 縦1カラム・全て中央揃え: rline(top) → photo (背後に巨大 number) →
   * name → meta → cta → rline(bottom). カードは全幅 (padding 0),
   * 高さはコンテンツ成り行き. photo は絶対配置のまま中央へ移し,
   * .content の padding-top で photo ぶんの空間を確保する. */
  @media (max-width: 720px) {
    .hero-wrap { padding: 0; }
    .hero-card {
      aspect-ratio: auto;
      min-height: auto;
    }
    /* info を flow に戻して card の高さを決めさせる (全幅・中央) */
    .info {
      position: static;
      inset: auto;
    }
    .content {
      position: relative;
      z-index: 3;
      /* 名前 (TAKAHARA) が photo の股あたりに重なる高さに合わせる */
      padding-top: 300px;
      gap: 20px;
    }
    .photo {
      right: auto;
      left: 50%;
      top: 110px;
      height: 610px;
      transform: translateX(-50%);
      /* スクリム (z:2) より下, bg-number (z:1, tree順で先) より上 */
      z-index: 1;
    }
    /* 本家の再現: 写真を透明にするのではなく, 名前より下の領域に
     * backdrop blur + 暗色グラデのスクリムをかけて体を曇らせながら沈める */
    .hero-card::after {
      content: '';
      position: absolute;
      inset: 0;
      z-index: 2;
      pointer-events: none;
      backdrop-filter: blur(9px);
      -webkit-backdrop-filter: blur(9px);
      /* 消し始めは 38-40% (腰上) のまま, ease-in で一気に加速して 60% 手前で消し切る */
      mask-image: linear-gradient(180deg, transparent 38%, rgb(0 0 0 / 0.35) 46%, #000 55%);
      -webkit-mask-image: linear-gradient(180deg, transparent 38%, rgb(0 0 0 / 0.35) 46%, #000 55%);
      background: linear-gradient(
        180deg,
        transparent 40%,
        color-mix(in srgb, var(--team-primary-dark) 25%, transparent) 47%,
        color-mix(in srgb, var(--team-primary-dark) 70%, transparent) 54%,
        var(--team-primary-dark) 60%
      );
    }
    /* rline はスクリムより手前に出す (bottom の白線が沈まないように) */
    .rline { z-index: 3; }
    .bg-number {
      right: auto;
      left: 50%;
      top: 290px;
      bottom: auto;
      transform: translate(-50%, -50%);
      font-size: clamp(190px, 60vw, 300px);
    }
    h1 { font-size: clamp(40px, 11vw, 58px); }
    .meta { flex-wrap: wrap; justify-content: center; }
  }
</style>
