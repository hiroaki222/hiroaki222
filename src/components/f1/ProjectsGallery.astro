---
import type { Project } from '@/lib/profile'
import SectionHeader from '@/components/f1/SectionHeader.astro'
interface Props {
  projects: Project[]
  id?: string
}
const { projects, id = 'projects' } = Astro.props
---

<section class="gallery-section" id={id}>
  <div class="gallery-inner">
    <SectionHeader title="Projects" />
    <div class="articles">
      {projects.map((p) => {
        const Tag = (p.url ? 'a' : 'div') as 'a' | 'div'
        return (
          <Tag
            class="article"
            href={p.url ?? undefined}
            target={p.url ? '_blank' : undefined}
            rel={p.url ? 'noopener noreferrer' : undefined}
          >
            <div class="body">
              <div class="meta">
                <span class:list={['cat', p.todo && 'todo']}>{p.category}</span>
                <span class:list={['time', p.todo && 'todo']}>{p.year}</span>
              </div>
              <h3 class:list={[p.todo && 'todo']}>{p.name}</h3>
              <p class:list={['i18n-ja', p.todo && 'todo']}>{p.description}</p>
              <p class:list={['i18n-en', p.todo && 'todo']}>{p.descriptionEn ?? p.description}</p>
              {p.url ? (
                // GitHub repo へ飛ぶものは View Repo, それ以外 (論文・詳細ページ等) は Read More
                <span class="more">{p.url.includes('github.com') ? 'View Repo' : 'Read More'}</span>
              ) : (
                <span class="more locked">Private Repo</span>
              )}
            </div>
          </Tag>
        )
      })}
    </div>
  </div>
</section>

<style>
  .gallery-section {
    background: var(--f1-dark);
    padding: 48px 48px;
  }
  @media (max-width: 720px) {
    .gallery-section { padding: 40px 8px; }
  }
  .gallery-inner { max-width: var(--container); margin: 0 auto; }
  .articles {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
  }
  .article {
    background: var(--f1-dark-2);
    border: 1px solid var(--rule);
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    color: inherit;
    text-decoration: none;
  }
  .article:hover { text-decoration: none; }
  .meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-bottom: 12px;
  }
  .cat {
    background: var(--f1-red);
    color: white;
    font-family: var(--font-display);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    padding: 4px 10px;
    font-weight: 800;
  }
  .time {
    color: var(--f1-muted);
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 600;
    white-space: nowrap;
  }
  .body { padding: 16px 20px 20px; display: flex; flex-direction: column; flex: 1; }
  .body p:last-of-type { margin-bottom: 0; }
  .body .more { margin-top: auto; padding-top: 12px; }
  h3 {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.01em;
    line-height: 1.2;
    margin: 0 0 8px;
  }
  p {
    color: var(--f1-muted);
    font-size: 13px;
    margin: 0 0 12px;
    line-height: 1.55;
  }
  .more {
    font-family: var(--font-display);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--f1-red);
    font-weight: 900;
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .more::after { content: '→'; font-size: 14px; }
  /* url 無し (社内/private) の明示: リンク不可であることを色で伝える */
  .more.locked { color: var(--f1-muted); cursor: default; }
  .more.locked::after { content: none; }
  .todo { color: var(--f1-muted); font-style: italic; }
</style>
