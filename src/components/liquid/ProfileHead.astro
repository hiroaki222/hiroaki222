---
interface Props {
  nameJa: string
  nameEn: string
  role: string
  githubUrl: string
  emailUser?: string | null
  emailDomain?: string | null
}
const { nameJa, nameEn, role, githubUrl, emailUser, emailDomain } = Astro.props
---

<div class="profile-head">
  <div>
    <h1>{nameJa} / {nameEn}</h1>
    <div class="role">{role}</div>
    <div class="links">
      <a href={githubUrl} target="_blank" rel="noopener noreferrer">GitHub</a>
      {emailUser
        ? <a class="email" data-u={emailUser} data-d={emailDomain} href="#contact">Show email</a>
        : <a href="mailto:#" class="todo">[email TODO]</a>}
    </div>
  </div>
</div>

<script>
  // email はスパム収集 bot 対策で data-u / data-d に分割してある (F1 InfoFooter と同方式).
  // 1回目の click で組み立てて表示+mailto 化, 2回目以降は通常の mailto リンク.
  document.querySelectorAll<HTMLAnchorElement>('a.email[data-u]').forEach((a) => {
    a.addEventListener('click', (e) => {
      if (a.dataset.revealed) return
      e.preventDefault()
      const addr = `${a.dataset.u}@${a.dataset.d}`
      a.textContent = addr
      a.href = `mailto:${addr}`
      a.dataset.revealed = '1'
    })
  })
</script>

<style>
  .profile-head {
    display: flex;
    gap: 20px;
    align-items: center;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--rule);
    margin-bottom: 24px;
  }
  h1 {
    font-size: 22px;
    font-weight: 600;
    margin: 0 0 2px;
    letter-spacing: -0.02em;
  }
  .role {
    color: var(--muted);
    font-size: 13px;
    margin-bottom: 8px;
  }
  .links { display: flex; gap: 6px; flex-wrap: wrap; }
  .links a {
    padding: 4px 12px;
    background: rgba(255, 255, 255, 0.35);
    color: var(--text);
    border: 1px solid var(--glass-border);
    border-radius: 999px;
    font-size: 12px;
    text-decoration: none;
    font-weight: 500;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }
  .links a:hover { background: rgba(255, 255, 255, 0.55); }
  @media (prefers-color-scheme: dark) {
    .links a { background: rgba(255, 255, 255, 0.08); }
    .links a:hover { background: rgba(255, 255, 255, 0.15); }
  }
  .todo { color: var(--muted); font-style: italic; font-size: 12px; }
</style>
