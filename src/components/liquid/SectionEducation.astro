---
import { renderInline } from '@/lib/profile'
import type { EducationEntry } from '@/lib/profile'
interface Props {
  entries: EducationEntry[]
}
const { entries } = Astro.props
---

<section id="education">
  <h2>Education</h2>
  <div class="glass-panel">
    {entries.map((e) => (
      <div class="row">
        <div>
          <div class:list={['title', e.todo && 'todo']}>
            <span class="i18n-ja">{e.institution}</span>
            <span class="i18n-en">{e.institutionEn ?? e.institution}</span>
          </div>
          <div class:list={['desc', e.todo && 'todo']}>
            <span class="i18n-ja" set:html={renderInline(`${e.program}${e.note ? ` · ${e.note}` : ''}`)} />
            <span
              class="i18n-en"
              set:html={renderInline(
                `${e.programEn ?? e.program}${(e.noteEn ?? e.note) ? ` · ${e.noteEn ?? e.note}` : ''}`,
              )}
            />
          </div>
        </div>
        <div class="date">
          <span class="i18n-ja">{e.years}</span>
          <span class="i18n-en">{e.yearsEn ?? e.years}</span>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .glass-panel {
    background: rgba(255, 255, 255, 0.3);
    backdrop-filter: blur(20px) saturate(160%);
    -webkit-backdrop-filter: blur(20px) saturate(160%);
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    padding: 2px 0;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06), inset 0 1px 0 rgba(255, 255, 255, 0.5);
  }
  @media (prefers-color-scheme: dark) {
    .glass-panel {
      background: rgba(255, 255, 255, 0.05);
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3), inset 0 1px 0 rgba(255, 255, 255, 0.1);
    }
  }
  .row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 12px;
    padding: 10px 14px;
    border-top: 1px solid var(--rule);
    align-items: baseline;
  }
  .row:first-child { border-top: none; }
  .title { font-weight: 500; }
  .desc { color: var(--muted); font-size: 12px; margin-top: 2px; grid-column: 1 / -1; }
  .date { color: var(--muted); font-size: 12px; font-variant-numeric: tabular-nums; }
  .todo { color: var(--muted); font-style: italic; font-size: 12px; }
</style>
