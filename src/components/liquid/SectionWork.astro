---
// work.md (work + internships) の liquid 表示. Education と同じ glass-panel リスト.
// internships は Career 本体と分けて小さめのサブリストにする (F1 の Loan Spells 相当).
import { renderInline } from '@/lib/profile'
import type { EducationEntry, LoanEntry } from '@/lib/profile'
interface Props {
  entries: EducationEntry[]
  internships?: LoanEntry[]
}
const { entries, internships = [] } = Astro.props
---

<section id="work">
  <h2>Work</h2>
  <div class="glass-panel">
    {entries.map((e) => (
      <div class="row">
        <div>
          <div class:list={['title', e.todo && 'todo']}>
            <span class="i18n-ja">{e.institution}</span>
            <span class="i18n-en">{e.institutionEn ?? e.institution}</span>
          </div>
          <div class:list={['desc', e.todo && 'todo']}>
            <span class="i18n-ja" set:html={renderInline(`${e.program}${e.note ? ` · ${e.note}` : ''}`)} />
            <span
              class="i18n-en"
              set:html={renderInline(
                `${e.programEn ?? e.program}${(e.noteEn ?? e.note) ? ` · ${e.noteEn ?? e.note}` : ''}`,
              )}
            />
          </div>
          {e.details && (
            <ul class="details">
              {e.details.map((d, idx) => (
                <li>
                  <span class="i18n-ja" set:html={renderInline(d)} />
                  <span class="i18n-en" set:html={renderInline(e.detailsEn?.[idx] ?? d)} />
                </li>
              ))}
            </ul>
          )}
        </div>
        <div class="date">
          <span class="i18n-ja">{e.years}</span>
          <span class="i18n-en">{e.yearsEn ?? e.years}</span>
        </div>
      </div>
    ))}
  </div>
  {internships.length > 0 && (
    <>
      <h3>Internships</h3>
      <div class="glass-panel">
        {internships.map((i) => (
          <div class="row slim">
            <div class="title">
              <span class="i18n-ja">{i.institution}</span>
              <span class="i18n-en">{i.institutionEn ?? i.institution}</span>
            </div>
            <div class="date">
              <span class="i18n-ja">{i.years}</span>
              <span class="i18n-en">{i.yearsEn ?? i.years}</span>
            </div>
          </div>
        ))}
      </div>
    </>
  )}
</section>

<style>
  .glass-panel {
    background: rgba(255, 255, 255, 0.3);
    backdrop-filter: blur(20px) saturate(160%);
    -webkit-backdrop-filter: blur(20px) saturate(160%);
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    padding: 2px 0;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06), inset 0 1px 0 rgba(255, 255, 255, 0.5);
  }
  @media (prefers-color-scheme: dark) {
    .glass-panel {
      background: rgba(255, 255, 255, 0.05);
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3), inset 0 1px 0 rgba(255, 255, 255, 0.1);
    }
  }
  h3 {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
    margin: 14px 0 8px;
  }
  .row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 12px;
    padding: 10px 14px;
    border-top: 1px solid var(--rule);
    align-items: baseline;
  }
  .row:first-child { border-top: none; }
  .row.slim { padding: 7px 14px; }
  .row.slim .title { font-size: 12.5px; font-weight: 400; }
  .title { font-weight: 500; }
  .desc { color: var(--muted); font-size: 12px; margin-top: 2px; grid-column: 1 / -1; }
  .details {
    margin: 4px 0 0;
    padding-left: 16px;
    color: var(--muted);
    font-size: 12px;
  }
  .details li { margin: 2px 0; }
  .date { color: var(--muted); font-size: 12px; font-variant-numeric: tabular-nums; }
  .todo { color: var(--muted); font-style: italic; font-size: 12px; }
</style>
