---
// エンジニアリング特化のファイルツリー sidebar.
// src/data/ の実ファイル構成 (トピック md + projects/ ディレクトリ) をそのまま
// ツリーとして表示し, 各ノードは対応セクションへのアンカーになる.
// 各プロジェクトはディレクトリとして readme.md (セクションへ) と
// github.url (repo へ) をネストする. 並びは全てアルファベット昇順.
import type { Project } from '@/lib/profile'
interface Props {
  projects: Project[]
  githubUrl: string
}
const { projects, githubUrl } = Astro.props

const byName = (a: string, b: string) => a.localeCompare(b)

// ルート直下のノード. projects/ (ソースの実ディレクトリ) も名前順に混ぜて並べる.
type Node =
  | { kind: 'file'; file: string; href: string; external?: boolean }
  | { kind: 'projects'; file: string }
const rootNodes: Node[] = (
  [
    { kind: 'file', file: 'bio.md', href: '#about' },
    { kind: 'file', file: 'education.md', href: '#education' },
    { kind: 'file', file: 'github.url', href: githubUrl, external: true },
    { kind: 'file', file: 'meta.md', href: '#profile' },
    { kind: 'projects', file: 'projects' },
    { kind: 'file', file: 'research.md', href: '#research' },
    { kind: 'file', file: 'skills.md', href: '#skills' },
    { kind: 'file', file: 'work.md', href: '#work' },
  ] satisfies Node[]
).sort((a, b) => byName(a.file, b.file))

// デプロイ済みプロダクトへのリンク. src/data ツリーとは独立したセクションとして
// sidebar 下部に列挙する (増えたらここに足す).
const products = [
  { file: 'h-takahara.url', href: 'https://h-takahara.com', external: true },
  { file: 'rating.url', href: '/rating', external: false },
].sort((a, b) => byName(a.file, b.file))

const sortedProjects = [...projects].sort((a, b) => byName(a.slug, b.slug))

// プロジェクトの外部リンクは中身に合わせた .url ファイル名にする
// (GitHub repo とは限らない — arxiv 論文などもある).
const urlFileName = (url: string) => {
  if (url.includes('github.com')) return 'github.url'
  if (url.includes('arxiv.org')) return 'arxiv.url'
  return 'link.url'
}

const fileIcon =
  '<path d="M4 1.5h5.5L13 5v9.5H4V1.5z" fill="none" stroke="currentColor" stroke-width="1.2"/><path d="M9.5 1.5V5H13" fill="none" stroke="currentColor" stroke-width="1.2"/>'
const folderIcon =
  '<path d="M1.5 3.5h4.8l1.2 1.8h7v7.2h-13V3.5z" fill="none" stroke="currentColor" stroke-width="1.2"/>'
const linkIcon =
  '<path d="M4 1.5h5.5L13 5v9.5H4V1.5z" fill="none" stroke="currentColor" stroke-width="1.2"/><path d="M6.5 9.5l3-3M7 4.5h4.5V9" fill="none" stroke="currentColor" stroke-width="1.2"/>'
const chevron =
  '<path d="M6 4l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>'
---

<nav class="sidebar">
  <div class="tree-label">src/data</div>

  {rootNodes.map((n) =>
    n.kind === 'file' ? (
      <a
        class="node"
        href={n.href}
        title={n.file}
        target={n.external ? '_blank' : undefined}
        rel={n.external ? 'noopener noreferrer' : undefined}
      >
        <span class="icon" set:html={`<svg viewBox="0 0 16 16">${n.external ? linkIcon : fileIcon}</svg>`} />
        <span class="name">{n.file}</span>
      </a>
    ) : (
      <details open>
        <summary class="node dir">
          <span class="chevron"><svg viewBox="0 0 16 16" set:html={chevron} /></span>
          <span class="icon" set:html={`<svg viewBox="0 0 16 16">${folderIcon}</svg>`} />
          <span class="name">projects/</span>
        </summary>
        <div class="children">
          {sortedProjects.map((p) => (
            <details>
              <summary class="node dir">
                <span class="chevron"><svg viewBox="0 0 16 16" set:html={chevron} /></span>
                <span class="icon" set:html={`<svg viewBox="0 0 16 16">${folderIcon}</svg>`} />
                <span class="name">{p.slug}/</span>
              </summary>
              <div class="children">
                <a class="node" href={`#project-${p.slug}`} title="readme.md">
                  <span class="icon" set:html={`<svg viewBox="0 0 16 16">${fileIcon}</svg>`} />
                  <span class="name">readme.md</span>
                </a>
                {p.url && (
                  <a class="node" href={p.url} title={urlFileName(p.url)} target="_blank" rel="noopener noreferrer">
                    <span class="icon" set:html={`<svg viewBox="0 0 16 16">${linkIcon}</svg>`} />
                    <span class="name">{urlFileName(p.url)}</span>
                  </a>
                )}
              </div>
            </details>
          ))}
        </div>
      </details>
    ),
  )}

  <div class="tree-label products-head">products</div>
  {products.map((p) => (
    <a
      class="node"
      href={p.href}
      title={p.file}
      target={p.external ? '_blank' : undefined}
      rel={p.external ? 'noopener noreferrer' : undefined}
    >
      <span class="icon" set:html={`<svg viewBox="0 0 16 16">${linkIcon}</svg>`} />
      <span class="name">{p.file}</span>
    </a>
  ))}
</nav>

<script>
  // Sidebar: ツリーのアンカーをクリックすると .main (window scroll region) の
  // 該当セクション / プロジェクト row までスクロールし, 到着先を一瞬ハイライトする.
  // スクロール位置に応じた active 表示も行う.
  const links = document.querySelectorAll<HTMLAnchorElement>('.sidebar a[href^="#"]')
  const main = document.querySelector<HTMLElement>('.main')

  if (main) {
    // offsetTop は positioned ancestor 基準でズレるので rect ベースで測る.
    const topOf = (el: HTMLElement) =>
      el.getBoundingClientRect().top - main.getBoundingClientRect().top + main.scrollTop

    const pairs = [...links]
      .map((a) => ({ a, el: document.getElementById(a.getAttribute('href')!.slice(1)) }))
      .filter((p): p is { a: HTMLAnchorElement; el: HTMLElement } => p.el !== null)

    const updateActive = () => {
      // ツリーの並びはページ順と無関係 (アルファベット降順) なので,
      // 「しきい値を超えた中でページ内位置が最も下のもの」を選ぶ.
      const scrollTop = main.scrollTop
      let current: { a: HTMLAnchorElement; top: number } | null = null
      for (const { a, el } of pairs) {
        const top = topOf(el)
        if (top - 40 <= scrollTop && (!current || top > current.top)) current = { a, top }
      }
      pairs.forEach(({ a }) => a.classList.toggle('active', a === current?.a))
    }
    updateActive()
    main.addEventListener('scroll', updateActive, { passive: true })

    pairs.forEach(({ a, el }) =>
      a.addEventListener('click', (e) => {
        e.preventDefault()
        main.scrollTo({ top: topOf(el) - 20, behavior: 'smooth' })
        el.animate(
          [
            { backgroundColor: 'rgba(0, 122, 255, 0.14)' },
            { backgroundColor: 'rgba(0, 122, 255, 0)' },
          ],
          { duration: 1200, delay: 250 },
        )
      }),
    )
  }
</script>

<style>
  .sidebar {
    padding: 12px 8px;
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-right: 1px solid var(--rule);
    overflow-y: auto;
    font-family: ui-monospace, 'SF Mono', SFMono-Regular, Menlo, Consolas, monospace;
  }
  @media (prefers-color-scheme: dark) {
    .sidebar { background: rgba(0, 0, 0, 0.15); }
  }
  .tree-label {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    padding: 4px 10px 8px;
  }
  .products-head {
    margin-top: 14px;
    padding-top: 12px;
    border-top: 1px solid var(--rule);
  }
  .node {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 4px 8px;
    border-radius: 7px;
    color: var(--text);
    text-decoration: none;
    font-size: 11.5px;
    margin-bottom: 1px;
    transition: background 0.15s;
    cursor: pointer;
    min-width: 0;
  }
  .node:hover { background: var(--sidebar-hover); }
  a.node.active {
    background: var(--sidebar-sel);
    color: white;
    box-shadow: 0 2px 8px rgba(0, 122, 255, 0.3), inset 0 1px 0 rgba(255, 255, 255, 0.3);
  }
  a.node.active .icon,
  a.node.active .chevron { color: white; }
  .name {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0;
  }
  .icon,
  .chevron {
    width: 14px;
    height: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--muted);
    flex-shrink: 0;
  }
  .icon :global(svg),
  .chevron :global(svg) { width: 13px; height: 13px; }

  /* ---- directories (details/summary) ---- */
  summary.dir { list-style: none; user-select: none; }
  summary.dir::-webkit-details-marker { display: none; }
  .chevron :global(svg) { transition: transform 0.15s; }
  details[open] > summary .chevron :global(svg) { transform: rotate(90deg); }
  .children {
    margin-left: 15px;
    padding-left: 6px;
    border-left: 1px solid var(--rule);
  }
</style>
