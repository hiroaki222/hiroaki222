---
interface Props {
  currentSeason: string
}
const { currentSeason } = Astro.props
---

<header class="top">
  <a class="back" href="/">← hiroaki222.com</a>
  <div class="top-right">
    <span class="top-season">{currentSeason} Ratings</span>
    <span class="lang-toggle">
      <button data-set-lang="ja">JA</button>
      <span class="lang-sep">/</span>
      <button data-set-lang="en">EN</button>
    </span>
  </div>
</header>
