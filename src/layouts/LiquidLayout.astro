---
import '@/components/liquid/tokens.css'
import { profile } from '@/lib/profile'
import TitleBar from '@/components/liquid/TitleBar.astro'
import Sidebar from '@/components/liquid/Sidebar.astro'
import ProfileHead from '@/components/liquid/ProfileHead.astro'
import SectionAbout from '@/components/liquid/SectionAbout.astro'
import SectionEducation from '@/components/liquid/SectionEducation.astro'
import SectionWork from '@/components/liquid/SectionWork.astro'
import SectionResearch from '@/components/liquid/SectionResearch.astro'
import SectionSkills from '@/components/liquid/SectionSkills.astro'
import SectionProjects from '@/components/liquid/SectionProjects.astro'
import SectionProfile from '@/components/liquid/SectionProfile.astro'

---

<!doctype html>
<html lang="ja" data-lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      // 言語初期化 (F1Layout と同方式): localStorage → ブラウザ言語. FOUC 防止で head 内.
      const lang =
        localStorage.getItem('lang') ||
        ((navigator.language || '').toLowerCase().startsWith('ja') ? 'ja' : 'en')
      document.documentElement.dataset.lang = lang
      document.documentElement.lang = lang
    </script>
    <title>エンジニアポートフォリオ — hiroaki222.com</title>
    <meta name="description" content={`${profile.nameEn} (${profile.nameJa}) — ${profile.role}`} />
    <link rel="icon" type="image/png" href="/favicon-liquid.png" />
    <link rel="apple-touch-icon" href="/favicon-liquid.png" />
    <meta property="og:title" content="エンジニアポートフォリオ — hiroaki222.com" />
    <meta property="og:description" content={`${profile.nameEn} (${profile.nameJa}) — ${profile.role}`} />
    <meta property="og:image" content="/favicon-liquid.png" />
    <meta property="og:type" content="profile" />
    <meta name="twitter:card" content="summary" />
  </head>
  <body>
    <div class="window">
      <TitleBar title={profile.nameJa} subtitle="hiroaki222.com" iconSrc="/favicon-liquid.png" />
      <div class="body grid grid-cols-[220px_1fr] min-h-0 max-[640px]:grid-cols-1">
        <Sidebar projects={profile.projects} githubUrl={profile.contact.github} />
        <main class="main overflow-y-auto scroll-smooth px-9 py-7 max-[640px]:px-5 max-[640px]:py-6">
          <ProfileHead
            nameJa={profile.nameJa}
            nameEn={profile.nameEn}
            role={profile.role}
            githubUrl={profile.contact.github}
            emailUser={profile.contact.emailUser}
            emailDomain={profile.contact.emailDomain}
          />
          {/* エンジニアリング比重: bio → skills → projects を先頭に, 残りは後ろへ */}
          <SectionAbout
            bio={profile.bio}
            bioEn={profile.bioEn}
            outro={profile.bioOutro?.liquid}
            outroEn={profile.bioOutro?.liquidEn}
          />
          <SectionSkills groups={profile.skills} assessment={profile.assessment} />
          <SectionProjects projects={profile.projects} />
          <SectionEducation entries={profile.education} />
          <SectionWork entries={profile.work ?? []} internships={profile.internships} />
          <SectionResearch research={profile.research} researchEn={profile.researchEn} />
          <SectionProfile profile={profile} />
        </main>
      </div>
    </div>
  </body>
</html>

<style>
  /* --------- Window frame (Liquid Glass) --------- */
  .window {
    width: 100%;
    max-width: 980px;
    background: var(--glass-bg);
    backdrop-filter: blur(30px) saturate(180%);
    -webkit-backdrop-filter: blur(30px) saturate(180%);
    border: 1px solid var(--glass-border);
    border-radius: 16px;
    box-shadow: var(--glass-shadow);
    overflow: hidden;
    display: grid;
    grid-template-rows: auto 1fr;
    /* window の高さを viewport に固定してスクロールを .main 内に閉じ込める.
     * (min-height だけだと window がコンテンツ分伸びて body スクロールになり,
     * sidebar のアンカージャンプ / スクロールスパイが効かなくなる) */
    height: calc(100vh - 64px);
    position: relative;
  }
  .window::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 16px;
    padding: 1px;
    background: linear-gradient(
      180deg,
      var(--glass-rim),
      transparent 40%,
      transparent 80%,
      rgba(255, 255, 255, 0.2)
    );
    -webkit-mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }

  /* --------- Body grid (sidebar + main) --------- */
  /* --------- Section shell shared across child components --------- */
  .main :global(section) {
    padding: 18px 0;
    border-bottom: 1px solid var(--rule);
    scroll-margin-top: 20px;
  }
  .main :global(section:last-child) { border-bottom: none; }
  .main :global(section > h2) {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
    margin: 0 0 12px;
  }
  .main :global(section p) { margin: 0 0 8px; font-size: 13px; }
  .main :global(section a) { color: var(--link); text-decoration: none; }
  .main :global(section a:hover) { text-decoration: underline; }

  /* Sidebar hides on narrow width */
  @media (max-width: 640px) {
    .body :global(.sidebar) { display: none; }
  }
</style>
